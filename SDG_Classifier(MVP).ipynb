    {
      "cell_type": "code",
      "source": [
        "print(predict_sdg_top3(\"A mobile app that improves rural healthcare and education access\"))"
      ],
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "id": "9FbRfd525zUN",
        "outputId": "76985c5c-0804-4c08-a3cc-2f19822d0df7"
      },
      "execution_count": 50,
      "outputs": [
        {
          "output_type": "stream",
          "name": "stdout",
          "text": [
            "['SDG 4', 'SDG 1', 'SDG 7']\n"
          ]
        }
      ]
    },
    {
      "cell_type": "code",
      "source": [
        "sdg_texts = list(sdgs.values())\n",
        "sdg_embeddings = model.encode(sdg_texts)"
      ],
      "metadata": {
        "id": "CvvORulQ5ANa"
      },
      "execution_count": 51,
      "outputs": []
    },
    {
      "cell_type": "code",
      "metadata": {
        "id": "be0a950c"
      },
      "source": [
        "def _predict_sdg_with_details(text):\n",
        "    text_embedding = model.encode(text)\n",
        "    similarities = cosine_similarity([text_embedding], sdg_embeddings)[0]\n",
        "\n",
        "    sdg_preds = []\n",
        "    for i, sim in enumerate(similarities):\n",
        "        sdg_code = list(sdgs.keys())[i]\n",
        "        sdg_description = sdgs[sdg_code]\n",
        "        sdg_preds.append((sdg_code, sdg_description, sim))\n",
        "\n",
        "    # Sort by similarity in descending order and return top 3\n",
        "    return sorted(sdg_preds, key=lambda x: x[2], reverse=True)[:3]"
      ],
      "execution_count": 52,
      "outputs": []
    },
    {
      "cell_type": "code",
      "metadata": {
        "id": "3e46cd2a"
      },
      "source": [
        "def predict_sdg(text):\n",
        "    preds_with_details = _predict_sdg_with_details(text)\n",
        "    if preds_with_details:\n",
        "        top_pred = preds_with_details[0]\n",
        "        return (top_pred[0], top_pred[1]) # Return (sdg_code, sdg_description)\n",
        "    return (None, None)\n",
        "\n",
        "def predict_sdg_top3(text):\n",
        "    preds_with_details = _predict_sdg_with_details(text)\n",
        "    return [p[0] for p in preds_with_details] # Return list of sdg_codes"
      ],
      "execution_count": 53,
      "outputs": []
    },
    {
      "cell_type": "code",
      "metadata": {
        "id": "51a8c928"
      },
      "source": [
        "def predict_sdg(text):\n",
        "    preds_with_details = _predict_sdg_with_details(text)\n",
        "    if preds_with_details:\n",
        "        top_pred = preds_with_details[0]\n",
        "        return (top_pred[0], top_pred[1]) # Return (sdg_code, sdg_description)\n",
        "    return (None, None)\n",
        "\n",
        "def predict_sdg_top3(text):\n",
        "    preds_with_details = _predict_sdg_with_details(text)\n",
        "    return [p[0] for p in preds_with_details] # Return list of sdg_codes"
      ],
      "execution_count": 54,
      "outputs": []
    },
    {
      "cell_type": "code",
      "metadata": {
        "id": "3a61c4fe"
      },
      "source": [
        "def evaluate(df_to_evaluate):\n",
        "    correct = 0\n",
        "    total_predictions = len(df_to_evaluate)\n",
        "\n",
        "    print(f\"Evaluating {total_predictions} projects...\")\n",
        "    for _, row in df_to_evaluate.iterrows():\n",
        "        pred_code, _ = predict_sdg(row[\"project\"])\n",
        "\n",
        "        # print(\"Project:\", row[\"project\"])\n",
        "        # print(\"Predicted:\", pred_code)\n",
        "        # print(\"Actual:\", row[\"actual_sdg\"])\n",
        "        # print(\"-----\")\n",
        "\n",
        "        if pred_code == row[\"actual_sdg\"]:\n",
        "            correct += 1\n",
        "\n",
        "    accuracy = correct / total_predictions\n",
        "    print(f\"Accuracy: {accuracy:.4f} ({correct}/{total_predictions})\\n\")"
      ],
      "execution_count": 55,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
